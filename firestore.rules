rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // A user is an admin if they have the dev email or their role in /users/{uid} is 'admin'
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'amanmahato321@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // examiner | org_admin | admin can create/manage exams
    function isExaminer() {
      return isSignedIn() && (
        request.auth.token.email == 'amanmahato321@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'org_admin', 'examiner'])
      );
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can see their own data, and admins can see everyone
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Admins can list all users for the management directory
      allow list: if isAdmin();
      // Allow users to create their initial profile OR admins to manage
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Exams ─────────────────────────────────────────────────────────────────

    match /exams/{examId} {
      // 1. Admins/Dev can read all
      // 2. Public can read if published
      // 3. Creator can read their own
      // 4. Org members can read exams for their org
      allow read: if isAdmin() 
                  || (resource.data.get('is_published', false) == true)
                  || (isSignedIn() && (
                      resource.data.get('created_by', '') == request.auth.uid ||
                      (resource.data.get('org_id', '') != '' && 
                       exists(/databases/$(database)/documents/org_members/$(request.auth.uid + '_' + resource.data.org_id)))
                  ));
      
      allow create: if isExaminer();
      allow update: if isAdmin() 
                    || (isSignedIn() && resource.data.get('created_by', '') == request.auth.uid);
      allow delete: if isAdmin();

      // Sub-collection Questions
      match /questions/{questionId} {
        allow read: if isAdmin() 
                    || isExaminer() 
                    || get(/databases/$(database)/documents/exams/$(examId)).data.get('is_published', false) == true
                    || get(/databases/$(database)/documents/exams/$(examId)).data.get('created_by', '') == request.auth.uid;
        allow write: if isAdmin() || isExaminer();
      }
    }

    // ── Questions (top-level flat structure for faster access) ────────────────

    match /questions/{questionId} {
      // Used by random/mixed assessments
      allow read: if true; 
      allow write: if isExaminer();
    }

    // ── Exam Attempts ─────────────────────────────────────────────────────────

    match /exam_attempts/{attemptId} {
      // Allow reading if it's yours, or if you're an admin/examiner
      allow read: if isAdmin() 
                  || (isSignedIn() && (resource.data.user_id == request.auth.uid || isExaminer()));
      
      // Allow list if admin, or student/examiner
      allow list: if isAdmin() || isSignedIn(); 

      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Leaderboard ───────────────────────────────────────────────────────────

    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if isSignedIn(); 
    }

    // ── Notifications ─────────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isAdmin() 
                  || (isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.user_id == 'all'));
      allow write: if isAdmin();
    }

    // ── Organizations ─────────────────────────────────────────────────────────

    match /organizations/{orgId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /org_members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isExaminer();
    }

    match /org_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.submitted_by == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Resources & Notes ────────────────────────────────────────────────────
    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin() || isExaminer();
    }
  }
}

